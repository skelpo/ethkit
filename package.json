{
  "name": "@skelpo/ethkit",
  "version": "0.1.1",
  "type": "module",
  "description": "Pure TypeScript Ethereum library. Lightweight, function-based drop-in replacement for ethers.js.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "npx tsx --test test/*.test.ts"
  },
  "keywords": [
    "ethereum",
    "ethers",
    "web3",
    "evm",
    "abi",
    "blockchain",
    "typescript",
    "perry"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/skelpo/ethkit.git"
  },
  "homepage": "https://github.com/skelpo/ethkit",
  "license": "MIT",
  "devDependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "ethers": "^6.13.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
